a) Consumos de tarjeta por año/mes

public class ConsumoDao extends GenericDao<Consumo, Long> {
    public ConsumoDao() { super(Consumo.class); }

    public List<Consumo> findByTarjetaAnioMes(Long idTarjeta, int anio, int mes) {
        EntityManager em = Jpautil.getEntityManager();
        try {
            String jpql = """
                select c from Consumo c
                where c.tarjeta.id = :idTarjeta
                  and c.anio = :anio
                  and c.mes = :mes
                order by c.dia
            """;
            return em.createQuery(jpql, Consumo.class)
                    .setParameter("idTarjeta", idTarjeta)
                    .setParameter("anio", anio)
                    .setParameter("mes", mes)
                    .getResultList();
        } finally {
            em.close();
        }
    }
}

b) Tarjetas sin liquidación en año/mes

public class TarjetaDao extends GenericDao<Tarjeta, Long> {
    public TarjetaDao() { super(Tarjeta.class); }

    public List<Tarjeta> findSinLiquidacion(int anio, int mes) {
        EntityManager em = Jpautil.getEntityManager();
        try {
            String jpql = """
                select t from Tarjeta t
                where not exists (
                    select l.id from Liquidacion l
                    where l.tarjeta = t
                      and l.anio = :anio
                      and l.mes = :mes
                )
            """;
            return em.createQuery(jpql, Tarjeta.class)
                    .setParameter("anio", anio)
                    .setParameter("mes", mes)
                    .getResultList();
        } finally {
            em.close();
        }
    }
}

c) Liquidación por número de tarjeta + año + mes

public class LiquidacionDao extends GenericDao<Liquidacion, Long> {
    public LiquidacionDao() { super(Liquidacion.class); }

    public Optional<Liquidacion> findByNumeroTarjetaAnioMes(String numero, int anio, int mes) {
        EntityManager em = Jpautil.getEntityManager();
        try {
            String jpql = """
                select l from Liquidacion l
                where l.tarjeta.numero = :numero
                  and l.anio = :anio
                  and l.mes = :mes
            """;
            return em.createQuery(jpql, Liquidacion.class)
                    .setParameter("numero", numero)
                    .setParameter("anio", anio)
                    .setParameter("mes", mes)
                    .getResultStream()
                    .findFirst();
        } finally {
            em.close();
        }
    }
}


