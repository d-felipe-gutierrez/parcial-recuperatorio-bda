package ar.edu.utnfrc.k5a.recuperatorio;

import ar.edu.utnfrc.k5a.recuperatorio.dao.ConsumoDao;
import ar.edu.utnfrc.k5a.recuperatorio.dao.LiquidacionDao;
import ar.edu.utnfrc.k5a.recuperatorio.dao.MonedaDao;
import ar.edu.utnfrc.k5a.recuperatorio.dao.TarjetaDao;
import ar.edu.utnfrc.k5a.recuperatorio.entities.Consumo;
import ar.edu.utnfrc.k5a.recuperatorio.entities.Moneda;
import ar.edu.utnfrc.k5a.recuperatorio.entities.Tarjeta;
import ar.edu.utnfrc.k5a.recuperatorio.util.Jpautil;

import java.util.List;

public class App {
    public static void main(String[] args) {
        TarjetaDao tarjetaDao = new TarjetaDao();
        ConsumoDao consumoDao = new ConsumoDao();
        LiquidacionDao liquidacionDao = new LiquidacionDao();
        MonedaDao monedaDao = new MonedaDao();

        try {
            // ---------------------------
            // READ ALL (ejemplo)
            // ---------------------------
            System.out.println("=== Tarjetas iniciales ===");
            tarjetaDao.findAll().forEach(t ->
                    System.out.println(t.getId() + " - " + t.getNumero() + " - " + t.getTitular())
            );

            // ---------------------------
            // CREATE Tarjeta
            // ---------------------------
            Tarjeta nueva = Tarjeta.builder()
                    .numero("4500123412340099")
                    .titular("Alumno Parcial")
                    .limiteCredito(500000.0)
                    .build();

            tarjetaDao.create(nueva);
            System.out.println("\nTarjeta creada con ID: " + nueva.getId());

            // ---------------------------
            // UPDATE Tarjeta
            // ---------------------------
            nueva.setTitular("Alumno Parcial Modificado");
            tarjetaDao.update(nueva);
            System.out.println("Tarjeta actualizada: " + nueva.getTitular());

            // ---------------------------
            // CREATE Consumo asociado
            // ---------------------------
            Moneda ars = monedaDao.findById("ARS")
                    .orElseThrow(() -> new RuntimeException("No existe moneda ARS"));

            Consumo consumo = Consumo.builder()
                    .tarjeta(nueva)
                    .moneda(ars)
                    .monto(12000.0)
                    .dia(10)
                    .mes(5)
                    .anio(2026)
                    .rubro("SUPERMERCADO")
                    .build();

            consumoDao.create(consumo);
            System.out.println("Consumo creado con ID: " + consumo.getId());

            // ---------------------------
            // CONSULTA 1:
            // Consumos por tarjeta + año + mes
            // ---------------------------
            List<Consumo> consumosMes = consumoDao.findByTarjetaAnioMes(nueva.getId(), 2026, 5);
            System.out.println("\nConsumos de tarjeta " + nueva.getNumero() + " en 05/2026: " + consumosMes.size());

            // ---------------------------
            // CONSULTA 2:
            // Tarjetas sin liquidación en año/mes
            // ---------------------------
            var sinLiq = tarjetaDao.findSinLiquidacion(2026, 5);
            System.out.println("Tarjetas sin liquidación en 05/2026: " + sinLiq.size());

            // ---------------------------
            // CONSULTA 3:
            // Liquidación por número + año + mes
            // ---------------------------
            var liq = liquidacionDao.findByNumeroTarjetaAnioMes("4500123412340001", 2026, 5);
            System.out.println("\nLiquidación tarjeta 0001 en 05/2026: " +
                    (liq.isPresent() ? ("ID " + liq.get().getId() + " - Total: " + liq.get().getTotalAPagar()) : "No encontrada"));

            // ---------------------------
            // DELETE (ejemplo)
            // Primero borro consumo, luego tarjeta (por FK)
            // ---------------------------
            consumoDao.deleteById(consumo.getId());
            tarjetaDao.deleteById(nueva.getId());
            System.out.println("\nBorrado de consumo y tarjeta de prueba OK");

        } finally {
            Jpautil.close(); // ojo: en tu util estaba "clise()", corregilo a close()
        }
    }
}


